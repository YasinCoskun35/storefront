is_global = true

# Require file-scoped namespaces (C# 10+)
csharp_style_namespace_declarations = file_scoped:warning

# Prefer 'var' for obvious types
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Prefer expression bodies for simple methods/properties
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# Prefer primary constructors where applicable
csharp_style_prefer_primary_constructors = true:suggestion

# Pattern matching
csharp_style_prefer_switch_expression = true:warning
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:warning

# Null checks
csharp_style_prefer_null_check_over_type_check = true:warning
dotnet_style_null_propagation = true:warning
dotnet_style_coalesce_expression = true:warning

# Naming rules
dotnet_naming_rule.private_fields_rule.symbols = private_fields
dotnet_naming_rule.private_fields_rule.style = underscore_prefix_camel_case
dotnet_naming_rule.private_fields_rule.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_prefix_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_prefix_camel_case.required_prefix = _

# Async method names should end with Async
dotnet_naming_rule.async_methods_rule.symbols = async_methods
dotnet_naming_rule.async_methods_rule.style = async_suffix_style
dotnet_naming_rule.async_methods_rule.severity = warning

dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async

dotnet_naming_style.async_suffix_style.capitalization = pascal_case
dotnet_naming_style.async_suffix_style.required_suffix = Async

# Use language keywords over framework types (int over Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# Unnecessary code
dotnet_diagnostic.IDE0058.severity = none
dotnet_diagnostic.IDE0290.severity = suggestion
