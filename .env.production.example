# ── Storefront production environment ──────────────────────────────────────
# Copy to .env.production, fill in values, then:
#   docker-compose -f docker-compose.prod.yml --env-file .env.production up -d

# Public URL where this customer's instance is reachable (no trailing slash).
# Used for CORS, password reset links, and iyzico redirect URLs.
PUBLIC_URL=https://portal.example.com

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=storefront
POSTGRES_USER=storefront_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT (generate with: openssl rand -base64 48) ────────────────────────────
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
JWT_ISSUER=Storefront.Api
JWT_AUDIENCE=Storefront.Web

# ── SMTP email (leave SMTP_HOST empty to disable email sending) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME=Storefront
# Receives an email for every new partner order request
ADMIN_NOTIFICATION_EMAIL=

# ── iyzico payments (leave empty to disable online balance payments) ────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Use https://api.iyzipay.com for live payments
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
