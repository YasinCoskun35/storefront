{
  "info": {
    "name": "Storefront API",
    "description": "Complete API collection for Storefront — B2B/B2C modular monolith platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "partnerToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "partnerId", "value": "" },
    { "key": "variantGroupId", "value": "" },
    { "key": "variantOptionId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "guestId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{adminToken}}" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [""] }
    }
  ],
  "item": [
    {
      "name": "Config",
      "item": [
        {
          "name": "Get App Mode",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/config/mode",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Identity — Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json).to.have.property('accessToken'));",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('adminToken', json.accessToken);",
                  "    console.log('Admin token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/identity/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@storefront.com\",\n  \"password\": \"AdminPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/identity/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token\"\n}"
            }
          }
        },
        {
          "name": "Partner Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json).to.have.property('accessToken'));",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('partnerToken', json.accessToken);",
                  "    console.log('Partner token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/identity/partners/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"partner@example.com\",\n  \"password\": \"PartnerPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Get Partner Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/identity/partners/profile",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{partnerToken}}" }] }
          }
        }
      ]
    },
    {
      "name": "Identity — Admin Partners",
      "item": [
        {
          "name": "Get All Partners",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/identity/admin/partners",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Create Partner Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('partnerId', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/identity/admin/partners",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Furniture\",\n  \"taxId\": \"1234567890\",\n  \"email\": \"info@acme.com\",\n  \"phone\": \"+905551234567\",\n  \"address\": \"123 Business St\",\n  \"city\": \"Istanbul\",\n  \"state\": \"Marmara\",\n  \"postalCode\": \"34000\",\n  \"country\": \"Turkey\",\n  \"industry\": \"Furniture\",\n  \"adminUser\": {\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"admin@acme.com\",\n    \"password\": \"PartnerPassword123!\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Partner Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/identity/admin/partners/{{partnerId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Approve Partner",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/identity/admin/partners/{{partnerId}}/approve",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Suspend Partner",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/identity/admin/partners/{{partnerId}}/suspend",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Add Partner User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/identity/admin/partners/{{partnerId}}/users",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@acme.com\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"password\": \"UserPassword123!\",\n  \"jobTitle\": \"Buyer\",\n  \"phoneNumber\": \"+905559876543\"\n}"
            }
          }
        },
        {
          "name": "Update Partner User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/identity/admin/partners/users/{{partnerUserId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"jobTitle\": \"Senior Buyer\",\n  \"phoneNumber\": \"+905559876543\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Reset Partner User Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/identity/admin/partners/users/{{partnerUserId}}/reset-password",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"NewPassword123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Identity — Admin Users",
      "item": [
        {
          "name": "Get Admin Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/identity/admin/users",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        }
      ]
    },
    {
      "name": "Catalog — Products",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/catalog/products?pageNumber=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "catalog", "products"],
              "query": [
                { "key": "searchTerm", "value": "", "disabled": true },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "brandId", "value": "", "disabled": true },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true },
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/catalog/products/{{productId}}",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('productId', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/catalog/products",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Modern 3-Seater Sofa\",\n  \"sku\": \"SOFA-3S-001\",\n  \"description\": \"Comfortable modern sofa with premium upholstery\",\n  \"shortDescription\": \"3-seater modern sofa\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"isActive\": true,\n  \"isFeatured\": true,\n  \"productType\": \"Simple\"\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/catalog/products/{{productId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Upload Product Image",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/catalog/products/{{productId}}/images?isPrimary=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "catalog", "products", "{{productId}}", "images"],
              "query": [{ "key": "isPrimary", "value": "true" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get Bundle Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/catalog/products/{{productId}}/bundle",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Add Component to Bundle",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/catalog/products/{{productId}}/components",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"componentProductId\": \"component-product-id\",\n  \"quantity\": 1,\n  \"isOptional\": false,\n  \"displayOrder\": 0\n}"
            }
          }
        },
        {
          "name": "Remove Component from Bundle",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/catalog/products/{{productId}}/components/{{componentId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        }
      ]
    },
