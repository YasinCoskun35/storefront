# Stage 1: Build
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copy solution and project files
COPY ["Storefront.sln", "./"]
COPY ["src/API/Storefront.Api/Storefront.Api.csproj", "src/API/Storefront.Api/"]
COPY ["src/Shared/Storefront.SharedKernel/Storefront.SharedKernel.csproj", "src/Shared/Storefront.SharedKernel/"]
COPY ["src/Infrastructure/Storefront.Infrastructure/Storefront.Infrastructure.csproj", "src/Infrastructure/Storefront.Infrastructure/"]
COPY ["src/Modules/Identity/Storefront.Modules.Identity/Storefront.Modules.Identity.csproj", "src/Modules/Identity/Storefront.Modules.Identity/"]
COPY ["src/Modules/Catalog/Storefront.Modules.Catalog/Storefront.Modules.Catalog.csproj", "src/Modules/Catalog/Storefront.Modules.Catalog/"]
COPY ["src/Modules/Content/Storefront.Modules.Content/Storefront.Modules.Content.csproj", "src/Modules/Content/Storefront.Modules.Content/"]

# Restore dependencies
RUN dotnet restore "src/API/Storefront.Api/Storefront.Api.csproj"

# Copy all source files
COPY . .

# Build and publish
WORKDIR "/src/src/API/Storefront.Api"
RUN dotnet publish "Storefront.Api.csproj" -c Release -o /app/publish \
    --no-restore \
    /p:UseAppHost=false

# Stage 2: Runtime
FROM mcr.microsoft.com/dotnet/aspnet:9.0-alpine AS runtime
WORKDIR /app

# Create uploads directory
RUN mkdir -p /app/uploads && chmod 777 /app/uploads

# Copy published files from build stage
COPY --from=build /app/publish .

# Expose port
EXPOSE 8080

# Set environment variables
ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

# Run application
ENTRYPOINT ["dotnet", "Storefront.Api.dll"]

