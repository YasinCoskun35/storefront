{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Override via env var: ConnectionStrings__DefaultConnection
    "DefaultConnection": ""
  },
  "Jwt": {
    // Override via env var: Jwt__Secret (min 32 chars, high entropy)
    "Secret": "",
    "Issuer": "Storefront.Api",
    "Audience": "Storefront.Web",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    // Override via env var: Cors__AllowedOrigins__0, Cors__AllowedOrigins__1, ...
    "AllowedOrigins": []
  },
  "Cookie": {
    // SameSite=Strict requires frontend and API on the same top-level domain.
    // For cross-origin dev setups, use SameSite=Lax in appsettings.Development.json.
    "SameSite": "Strict",
    "SecurePolicy": "Always",
    "AdminCookieName": "admin_token",
    "PartnerCookieName": "partner_token"
  },
  "RateLimit": {
    // Sliding window applied to all /auth/ login endpoints
    "AuthWindowSeconds": 60,
    "AuthPermitLimit": 10
  },
  "Iyzico": {
    // Override via env vars: Iyzico__ApiKey, Iyzico__SecretKey, Iyzico__CallbackUrl, etc.
    "ApiKey": "",
    "SecretKey": "",
    "BaseUrl": "https://sandbox-api.iyzipay.com",
    "CallbackUrl": "",
    "FrontendResultUrl": ""
  },
  "CatalogSettings": {
    "PricingEnabled": false,
    "RequirePriceForProducts": false,
    "ShowPriceLabel": "Contact for Quote",
    "AllowPriceInquiry": true
  },
  "AppMode": "B2B",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/storefront-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} [{MachineName}]: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
