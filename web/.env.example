# ── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in values for your environment.
# NEVER commit .env.local — it contains environment-specific configuration.

# Public API base URL (used by the browser and Next.js SSR)
# In production this should point to your API domain, e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# App mode — B2B only for this repo
NEXT_PUBLIC_APP_MODE=B2B

# Server-side API URL override (optional)
# Use when the Next.js server container reaches the API via an internal hostname
# e.g. API_URL=http://api:8080
# API_URL=http://localhost:8080
