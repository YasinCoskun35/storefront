# API base URL for the Storefront backend
# Required when running the app on a physical device (phone/tablet).
# Use your computer's LAN IP address so the device can reach the backend.
#
# Examples:
#   Physical device on same WiFi:  EXPO_PUBLIC_API_URL=http://192.168.1.100:8080
#   Physical device on same WiFi:  EXPO_PUBLIC_API_URL=http://10.0.0.5:8080
#
# Simulators/Emulators use defaults (no need to set):
#   iOS Simulator:     http://localhost:8080
#   Android Emulator:  http://10.0.2.2:8080
#
EXPO_PUBLIC_API_URL=http://YOUR_MACHINE_IP:8080
