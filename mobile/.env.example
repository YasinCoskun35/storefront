# ── Mobile App Environment Variables ─────────────────────────────────────────
# Copy to .env for local development.
# For production builds, set env vars in eas.json under build.production.env
# (never commit .env — it is gitignored).

# API base URL
# - Local dev (physical device):  http://YOUR_MACHINE_LAN_IP:8080
# - iOS Simulator (default):      http://localhost:8080      (auto-detected, no need to set)
# - Android Emulator (default):   http://10.0.2.2:8080       (auto-detected, no need to set)
# - Production build:             https://api.yourcompany.com (set in eas.json)
EXPO_PUBLIC_API_URL=http://YOUR_MACHINE_LAN_IP:8080
